# --- Node/TS ---
NODE_ENV=development
LOG_LEVEL=info
BUILD_TARGET=dev

# --- Postgres ---
POSTGRES_HOST=kairos-postgres
POSTGRES_DB=kairos
POSTGRES_USER=kairos
POSTGRES_PASSWORD=change-me-in-dev-only

# --- Redis ---
REDIS_HOST=kairos-redis

# --- MinIO ---
MINIO_ROOT_USER=kairos
MINIO_ROOT_PASSWORD=change-me-in-dev-only

# --- Vault ---
VAULT_URL=http://kairos-vault:9000
# Path on the host to the age master key file; mounted read-only into the vault container.
VAULT_MASTER_KEY_HOST_PATH=./.dev/master.key

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:3001/api/v1

# --- JWT (for dev; prod uses vault aliases) ---
JWT_ACCESS_SECRET=dev-only-change-me
JWT_REFRESH_SECRET=dev-only-change-me
APPROVAL_HMAC_SECRET=dev-only-change-me
CAPABILITY_TOKEN_SECRET=dev-only-change-me

# --- Providers (vault aliases resolved at runtime in prod) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Telemetry (optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
